{
  "title": "Docker Containers Overview",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "title": "CPU por contenedor",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{image!=\"\"}[2m])"
        }
      ],
      "gridPos": { "w": 12, "h": 6, "x": 0, "y": 0 }
    },
    {
      "title": "Memoria por contenedor",
      "type": "graph",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{image!=\"\"}"
        }
      ],
      "gridPos": { "w": 12, "h": 6, "x": 0, "y": 6 }
    }
  ]
}
